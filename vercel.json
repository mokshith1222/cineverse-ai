{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "images": {
    "sizes": [320, 640, 750, 1080, 1440],
    "domains": [
      "m.media-amazon.com",
      "cdn.myanimelist.net",
      "static.tvmaze.com",
      "placehold.co"
    ]
  }
}
